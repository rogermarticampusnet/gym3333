---
import Layout from '../layouts/Layout.astro'
import CartItem from '../components/CartItem.astro'
---
<Layout title="Shopping Cart">
    <main>
        <div class="bg-gray-100 w-5/6 h-full mx-auto rounded-lg mt-10 mb-10 py-10 text-center">
            <p class="text-xl font-bold">Shopping Cart</p>
            <CartItem 
            title="Lifestyle Subscription"
            description="Monthly memebership"
            quantity={1}
            price={19}/>
            <CartItem 
            title="Trial Training Subscription"
            description="3 days memebership"
            quantity={1}
            price={9.95}/>
        </div>
    </main>
    
</Layout>