---
import Layout from '../layouts/Layout.astro'
import CartItem from '../components/CartItem.astro'
---

<Layout title="Checkout">
	<main class="mb-20 grid grid-cols-2 gap-10">
		<div
			class="mx-auto mb-10 ml-40 mt-10 flex h-full w-full flex-col items-center justify-center rounded-lg bg-gray-100 text-center"
		>
			<p class="text-xl font-bold">Checkout</p>
			<CartItem
				title="Lifestyle Subscription"
				description="Monthly memebership"
				quantity={1}
				price={19}
			/>
			<CartItem
				title="Trial Training Subscription"
				description="3 days memebership"
				quantity={1}
				price={9.95}
			/>
			<div class="mt-10 w-2/4 rounded-lg bg-gray-950 px-8 py-8 text-center text-white">
				<p>Total price: <span class="price font-bold">28.95€</span></p>
			</div>
		</div>
		<!-- Payment details -->
		<div
			class="mx-auto mb-10 mt-10 flex h-full w-2/3 flex-col items-center justify-center rounded-lg bg-gray-100 text-center"
		>
			<form class="mx-auto block w-full grid-rows-5 items-center px-36 py-16 text-left">
				<div class="mb-6">
					<label for="email" class="mb-2 block text-sm font-medium text-gray-950"
						>Contact information</label
					>
					<input
						type="email"
						id="email"
						class="w-full rounded-md border-0 bg-white/5 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-[var(--ten)]"
						placeholder="Email"
						required
					/>
				</div>
				<hr class="mb-6" />
				<div class="mb-6">
					<label for="fname" class="mb-2 block text-sm font-medium text-gray-950">Full name</label>
					<input
						type="text"
						id="fname"
						class="w-full rounded-md border-0 bg-white/5 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-[var(--ten)]"
						placeholder="Enter your full name..."
						required
					/>
				</div>

				<div class="mb-6">
					<label for="address" class="mb-2 block text-sm font-medium text-gray-950">Address</label>
					<input
						type="text"
						id="address"
						class="w-full rounded-md border-0 bg-white/5 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-[var(--ten)]"
						placeholder="Enter your address..."
						required
					/>
				</div>

				<div class="mb-6">
					<label for="addressDetails" class="mb-2 block text-sm font-medium text-gray-950"
						>Apartment, door, etc</label
					>
					<input
						type="text"
						id="addressDetails"
						class="w-full rounded-md border-0 bg-white/5 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-[var(--ten)]"
						placeholder="Enter your house details..."
						required
					/>
				</div>

				<div class="mb-6">
					<label for="city" class="mb-2 block text-sm font-medium text-gray-950">City</label>
					<input
						type="text"
						id="city"
						class="w-full rounded-md border-0 bg-white/5 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-[var(--ten)]"
						placeholder="Enter your city..."
						required
					/>
				</div>

				<div class="mb-6">
					<label for="gym" class="mb-2 block text-sm font-medium text-gray-950"
						>Delivery method</label
					>
					<select
						id="gym"
						class="w-full rounded-md border-0 bg-white/5 px-3.5 py-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-[var(--ten)]"
						required
					>
						<option value="gym-origo">Standard (4-10 business days) - 4.00€</option>
						<option value="gym-imanta">Express (2-5 business days) - 16.00€</option>
					</select>
				</div>

				<div class="mb-6">
					<label for="gym" class="mb-2 block text-sm font-medium text-gray-950"
						>Payment method</label
					>
					<button
						class="mb-2 flex w-full flex-row justify-center rounded-lg bg-black py-2 text-center font-bold text-white"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="icon icon-tabler icon-tabler-brand-apple"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							fill="none"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
								d="M9 7c-3 0 -4 3 -4 5.5c0 3 2 7.5 4 7.5c1.088 -.046 1.679 -.5 3 -.5c1.312 0 1.5 .5 3 .5s4 -3 4 -5c-.028 -.01 -2.472 -.403 -2.5 -3c-.019 -2.17 2.416 -2.954 2.5 -3c-1.023 -1.492 -2.951 -1.963 -3.5 -2c-1.433 -.111 -2.83 1 -3.5 1c-.68 0 -1.9 -1 -3 -1z"
							></path><path d="M12 4a2 2 0 0 0 2 -2a2 2 0 0 0 -2 2"></path></svg
						>
					</button>
					<button
						class="mb-2 flex w-full flex-row justify-center rounded-lg bg-[#ffc439] py-2 text-center font-bold text-white"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="icon icon-tabler icon-tabler-brand-paypal-filled"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							fill="none"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
								d="M12.5 2c3.113 0 5.309 1.785 5.863 4.565c1.725 1.185 2.637 3.152 2.637 5.435c0 2.933 -2.748 5.384 -5.783 5.496l-.217 .004h-1.754l-.466 2.8a1.998 1.998 0 0 1 -1.823 1.597l-.157 .003h-2.68a1.5 1.5 0 0 1 -1.182 -.54a1.495 1.495 0 0 1 -.348 -1.07l.042 -.29h-1.632c-1.004 0 -1.914 -.864 -1.994 -1.857l-.006 -.143l.01 -.141l1.993 -13.954l.003 -.048c.072 -.894 .815 -1.682 1.695 -1.832l.156 -.02l.143 -.005h5.5zm5.812 7.35l-.024 .087c-.706 2.403 -3.072 4.436 -5.555 4.557l-.233 .006h-2.503v.05l-.025 .183l-1.2 5a1.007 1.007 0 0 1 -.019 .07l-.088 .597h2.154l.595 -3.564a1 1 0 0 1 .865 -.829l.121 -.007h2.6c2.073 0 4 -1.67 4 -3.5c0 -1.022 -.236 -1.924 -.688 -2.65z"
								stroke-width="0"
								fill="currentColor"></path></svg
						>
					</button>
					<button
						class="mb-2 flex w-full flex-row justify-center rounded-lg bg-[#635bff] py-2 text-center font-bold text-white"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="icon icon-tabler icon-tabler-brand-stripe"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							fill="none"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
								d="M11.453 8.056c0 -.623 .518 -.979 1.442 -.979c1.69 0 3.41 .343 4.605 .923l.5 -4c-.948 -.449 -2.82 -1 -5.5 -1c-1.895 0 -3.373 .087 -4.5 1c-1.172 .956 -2 2.33 -2 4c0 3.03 1.958 4.906 5 6c1.961 .69 3 .743 3 1.5c0 .735 -.851 1.5 -2 1.5c-1.423 0 -3.963 -.609 -5.5 -1.5l-.5 4c1.321 .734 3.474 1.5 6 1.5c2 0 3.957 -.468 5.084 -1.36c1.263 -.979 1.916 -2.268 1.916 -4.14c0 -3.096 -1.915 -4.547 -5 -5.637c-1.646 -.605 -2.544 -1.07 -2.544 -1.807z"
							></path></svg
						>
					</button>
				</div>
			</form>
		</div>
	</main>
</Layout>

<style>
	.price {
		color: var(--ten);
	}
	input[type='checkbox']:checked {
		background-color: var(--ten);
	}
	input {
		background-color: #1d2432;
	}
	select {
		background-color: #1d2432; /* Set the background color of the dropdown menu */
		color: white; /* Set the text color of the dropdown menu */
	}
</style>
